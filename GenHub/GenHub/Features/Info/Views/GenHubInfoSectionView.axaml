<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GenHub.Features.Info.ViewModels"
             xmlns:models="clr-namespace:GenHub.Core.Models.Info;assembly=GenHub.Core"
             xmlns:local="clr-namespace:GenHub.Features.GameProfiles.Views"
             xmlns:update="clr-namespace:GenHub.Features.AppUpdate.Views"
             xmlns:views="clr-namespace:GenHub.Features.Info.Views"
             xmlns:toolsRep="clr-namespace:GenHub.Features.Tools.ReplayManager.Views"
             xmlns:toolsMap="clr-namespace:GenHub.Features.Tools.MapManager.Views"
             xmlns:infra="clr-namespace:GenHub.Infrastructure.Controls;assembly=GenHub"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:notifications="clr-namespace:GenHub.Features.Notifications.Views"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="GenHub.Features.Info.Views.GenHubInfoSectionView"
             x:DataType="vm:GenHubInfoSectionViewModel">

  <UserControl.Styles>
    <!-- Section Header Style -->
    <Style Selector="TextBlock.section-header">
      <Setter Property="FontSize" Value="36"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="white"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Info Card Styles - Modern Premium Look -->
    <Style Selector="Border.info-card">
      <Setter Property="Background" Value="#252525"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderBrush" Value="#353535"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Margin" Value="0,0,0,24"/>
      <Setter Property="Padding" Value="24"/>
      <Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
    </Style>

    <Style Selector="TextBlock.card-title">
      <Setter Property="FontSize" Value="22"/> <!-- Larger title -->
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F0F0F0"/>
    </Style>

    <!-- Header for demos "Interactive Element" -->
    <Style Selector="TextBlock.demo-title">
       <Setter Property="FontSize" Value="24"/>
       <Setter Property="FontWeight" Value="Bold"/>
       <Setter Property="Foreground" Value="White"/>
    </Style>

     <Style Selector="TextBlock.demo-subtitle">
       <Setter Property="FontSize" Value="15"/>
       <Setter Property="Foreground" Value="#AAAAAA"/>
       <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <Style Selector="Border.demo-container">
        <Setter Property="Background" Value="#121212"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="40"/>
        <Setter Property="BorderBrush" Value="#303030"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,20,0,0"/>
    </Style>

    <!-- Shortcut Icon Mock Style -->
     <Style Selector="Border.shortcut-mock">
        <Setter Property="Width" Value="64"/>
        <Setter Property="Height" Value="64"/>
        <Setter Property="Background" Value="Transparent"/>
     </Style>

    <!-- ========================================== -->
    <!-- UNIFIED INFO SECTION STYLES               -->
    <!-- ========================================== -->
    <!-- Use these styles for consistent expandable info sections across all categories -->

    <!-- Main container for expandable info sections -->
    <Style Selector="Border.info-section">
        <Setter Property="Background" Value="#1A1A1A"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="#333333"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>

    <!-- Header button for expandable sections -->
    <Style Selector="Button.info-section-header">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Title text in section headers -->
    <Style Selector="TextBlock.info-section-title">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>



    <!-- Content container inside expandable sections -->
    <Style Selector="StackPanel.info-section-content">
        <Setter Property="Spacing" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
    </Style>

    <!-- Sub-section headings -->
    <Style Selector="TextBlock.info-subsection-title">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- Bullet point text -->
    <Style Selector="TextBlock.info-bullet">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#888888"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>



    <!-- Feature item title -->
    <Style Selector="TextBlock.info-feature-title">
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Feature item description -->
    <Style Selector="TextBlock.info-feature-desc">
        <Setter Property="Foreground" Value="#888888"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Overview/description paragraph -->
    <Style Selector="TextBlock.info-overview">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="22"/>
    </Style>

  </UserControl.Styles>

  <ScrollViewer Padding="60,40,60,40">
      <StackPanel Spacing="10" MaxWidth="1000" HorizontalAlignment="Center" ClipToBounds="False">

        <!-- Main Section Header -->
        <StackPanel Margin="0,0,0,50">
          <TextBlock Text="{Binding SelectedSection.Title}" Classes="section-header"/>
          <TextBlock Text="{Binding SelectedSection.Description}"
                     FontSize="18"
                     Foreground="#999999"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ============================================== -->
        <!-- DEMO: GAME PROFILES                            -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsGameProfilesSelected}" Margin="0,0,0,50">
          <StackPanel>
             <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Interactive Element: Game Profile Card" Classes="demo-title"/>
                <TextBlock Text="The core control surface for your games." Classes="demo-subtitle"/>
            </StackPanel>

            <Border Classes="demo-container">
              <StackPanel HorizontalAlignment="Center" Spacing="20">
                  <!-- Scaled down profile card for better fit -->
                  <Viewbox Stretch="Uniform" MaxHeight="400">
                      <local:GameProfileCardView DataContext="{Binding DemoProfileCard}" Width="300" Height="400"/>
                  </Viewbox>

                <TextBlock Text="Try hovering or clicking the buttons above!"
                           FontSize="13" Foreground="#666666" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- DEMO: SHORTCUTS                                -->
        <!-- ============================================== -->
        <Border Margin="0,0,0,50">
             <Border.IsVisible>
                <Binding Path="SelectedSection.Id" Converter="{x:Static ObjectConverters.Equal}" ConverterParameter="shortcuts"/>
             </Border.IsVisible>
             <StackPanel>
                <TextBlock Text="Interactive Element: Desktop Shortcut" Classes="demo-title"/>
                <TextBlock Text="How to create a quick launch icon." Classes="demo-subtitle"/>

                <Border Classes="demo-container">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="40" VerticalAlignment="Center">

                         <!-- 1. The Source: Profile Card -->
                         <StackPanel Spacing="10">
                             <TextBlock Text="1. Right-Click Profile" Foreground="#999" HorizontalAlignment="Center" FontWeight="Bold"/>
                             <Viewbox Stretch="Uniform" Width="240">
                                <!-- Using actual component for fidelity -->
                                <local:GameProfileCardView DataContext="{Binding DemoShortcutProfile}" Width="300" Height="400"/>
                             </Viewbox>
                             <TextBlock Text="Click the highlighted Pin icon" FontSize="11" Foreground="#666" HorizontalAlignment="Center" FontStyle="Italic"/>
                         </StackPanel>

                        <!-- Arrow -->
                        <PathIcon Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Width="32" Height="32" Foreground="#444" VerticalAlignment="Center" Margin="0,25,0,0"/>

                        <!-- 2. The Result: Desktop Icon -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="2. Created on Desktop" Foreground="#999" HorizontalAlignment="Center" FontWeight="Bold"/>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="8" Width="120" Margin="0,50,0,0">
                                 <!-- Windows Desktop Icon Look-alike -->
                                 <Border Background="Transparent" Padding="8">
                                     <StackPanel Spacing="2">
                                         <Grid Width="48" Height="48" HorizontalAlignment="Center">
                                            <Image Source="avares://GenHub/Assets/Icons/generalshub-icon.png" Width="48" Height="48"/>
                                            <!-- Shortcut Overlay Arrow -->
                                            <Border Background="White" Width="16" Height="16" CornerRadius="2" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,0" BorderBrush="#888" BorderThickness="1">
                                                <PathIcon Data="M10,2H19V11M19,2L6,15" Width="12" Height="12" Foreground="Black" RenderTransform="rotate(-45deg)" RenderTransformOrigin="50%,50%"/>
                                            </Border>
                                         </Grid>
                                         <TextBlock Text="Zero Hour Demo" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" FontSize="12"
                                                    Effect="drop-shadow(1 1 2 black)"/>
                                     </StackPanel>
                                 </Border>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: STEAM INTEGRATION                        -->
        <!-- ============================================== -->
         <Border Margin="0,0,0,50">
             <Border.IsVisible>
                <Binding Path="SelectedSection.Id" Converter="{x:Static ObjectConverters.Equal}" ConverterParameter="steam-integration"/>
             </Border.IsVisible>
             <StackPanel>
                <TextBlock Text="Interactive Element: Steam Overlay" Classes="demo-title"/>
                <TextBlock Text="Visual confirmation that Steam is Active." Classes="demo-subtitle"/>

                <Border Classes="demo-container">
                    <StackPanel HorizontalAlignment="Center" Spacing="20">
                        <TextBlock Text="Click the highlighted Steam icon to toggle integration."
                                   FontSize="13" Foreground="#666666" HorizontalAlignment="Center"/>

                        <Viewbox Stretch="Uniform" MaxHeight="400">
                             <local:GameProfileCardView DataContext="{Binding DemoSteamProfile}" Width="300" Height="400"/>
                        </Viewbox>

                         <TextBlock Text="(Icon turns Blue when Active)" Foreground="#00CCFF" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>



        <!-- ============================================== -->
        <!-- DEMO: APP UPDATE                               -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsAppUpdatesSelected}" Margin="0,15,0,0">
          <StackPanel Spacing="40">
            <!-- 1. Standard Update Mechanism -->
            <StackPanel Spacing="20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="CloudDownload" Width="24" Height="24" Foreground="{StaticResource SystemAccentColorBrush}"/>
                        <TextBlock Text="Automatic Updates" Classes="demo-title" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="GenHub uses the Velopack engine for seamless background updates. Use this notification bar to manage official releases."
                               Classes="demo-subtitle"/>

                    <!-- Detailed explanations (Standard Updates) -->
                    <StackPanel Margin="0,12,0,0" Spacing="12">
                        <!-- Mechanism Explained -->
                        <Border Background="#151515" CornerRadius="8" Padding="20" BorderBrush="#252525" BorderThickness="1" MaxWidth="1000" HorizontalAlignment="Left">
                            <StackPanel Spacing="15">
                                <TextBlock Text="How it works:" FontSize="13" FontWeight="SemiBold" Foreground="#9C27B0"/>
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <material:MaterialIcon Grid.Column="0" Kind="BellOutline" Width="18" Height="18" Foreground="#666" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                            <TextBlock Text="Notification" FontWeight="SemiBold" Foreground="#CCC" FontSize="13"/>
                                            <TextBlock Text="A 'New Update Available' bar appears at the bottom. The app checks every 4 hours automatically."
                                                      Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <material:MaterialIcon Grid.Column="0" Kind="ArrowDownBoldCircleOutline" Width="18" Height="18" Foreground="#666" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                            <TextBlock Text="Background Download" FontWeight="SemiBold" Foreground="#CCC" FontSize="13"/>
                                            <TextBlock Text="Updates are downloaded incrementally to save bandwidth. You can continue browsing or playing while it works."
                                                      Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <material:MaterialIcon Grid.Column="0" Kind="Restart" Width="18" Height="18" Foreground="#666" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                            <TextBlock Text="Instant Application" FontWeight="SemiBold" Foreground="#CCC" FontSize="13"/>
                                            <TextBlock Text="Click 'Restart to Update' to apply. The process takes roughly 5 seconds and resumes exactly where you left off."
                                                      Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="demo-container" Margin="0,10,0,0">
                          <StackPanel HorizontalAlignment="Center" Spacing="20">
                            <Border BorderBrush="#33000000" BorderThickness="1" CornerRadius="8" Background="#1E1E1E" ClipToBounds="True" MaxWidth="600">
                                <update:UpdateNotificationView DataContext="{Binding DemoUpdateNotification}"/>
                            </Border>
                            <TextBlock Text="Try clicking 'Browse Builds' to see experimental developer versions!"
                                       FontSize="12" Foreground="#666" HorizontalAlignment="Center" FontStyle="Italic"/>
                          </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- 2. GitHub PAT & CI Artifacts -->
            <StackPanel Spacing="20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="Github" Width="24" Height="24" Foreground="{StaticResource SystemAccentColorBrush}"/>
                        <TextBlock Text="Advanced: CI Artifacts &amp; GitHub PAT" Classes="demo-title" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Subscribe to pull requests or specific branches to test new features before they are merged."
                               Classes="demo-subtitle"/>

                    <!-- Detailed explanations (PAT & CI) -->
                    <StackPanel Margin="0,12,0,0" Spacing="15">
                        <TextBlock Text="CI (Continuous Integration) Artifacts are automated builds created by GitHub for every code change. To access these protected resources, GenHub requires a Personal Access Token."
                                   FontSize="13" Foreground="#AAAAAA" TextWrapping="Wrap" MaxWidth="1000"/>

                        <Grid ColumnDefinitions="*, *">
                            <!-- Column 1: Why PAT? -->
                            <Border Grid.Column="0" Background="#1A0F20" CornerRadius="8" Padding="20" BorderBrush="#3A1C40" BorderThickness="1" Margin="0,0,10,0">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Why is a PAT required?" FontSize="13" FontWeight="SemiBold" Foreground="#CE93D8"/>
                                    <TextBlock Text="GitHub requires authentication to download 'unreleased' artifacts. GenHub uses your token safely:
• Only 'repo' scope is needed.
• It never sees your password.
• Token is stored locally and encrypted."
                                              Foreground="#888888" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Column 2: Setup Workflow -->
                            <Border Grid.Column="1" Background="#151515" CornerRadius="8" Padding="20" BorderBrush="#252525" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Setup Process:" FontSize="13" FontWeight="SemiBold" Foreground="#9C27B0"/>
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="1. Go to GitHub -> Settings -> Developer Settings." Foreground="#888888" FontSize="12"/>
                                        <TextBlock Text="2. Create a 'Classic' PAT with 'repo' scope." Foreground="#888888" FontSize="12"/>
                                        <TextBlock Text="3. Paste the token below to unlock 'Browse Builds'." Foreground="#888888" FontSize="12"/>
                                        <TextBlock Text="4. Subscribe to any open feature or fix branch." Foreground="#888888" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Classes="demo-container" Margin="0,10,0,0">
                            <Border Background="#1E1E1E" CornerRadius="12" Padding="30" BorderBrush="#4E4E4E" BorderThickness="1" MaxWidth="600" HorizontalAlignment="Center">
                                <StackPanel Spacing="20" DataContext="{Binding DemoGameSettingsVM}">
                                     <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="🔑" FontSize="20" VerticalAlignment="Center" />
                                        <TextBlock Text="GitHub Personal Access Token"
                                                   FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" />
                                     </StackPanel>

                                     <!-- PAT Status -->
                                     <Border Background="#25FFFFFF" CornerRadius="6" Padding="12,8" HorizontalAlignment="Left">
                                         <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{Binding PatStatusColor}" />
                                            <TextBlock Text="{Binding PatStatusMessage}" Foreground="#EEE" FontSize="13" FontWeight="Medium" />
                                         </StackPanel>
                                     </Border>

                                     <!-- PAT Input -->
                                     <StackPanel Spacing="8">
                                         <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding GitHubPatInput}"
                                                     PasswordChar=""
                                                     Watermark="ghp_xxxxxxxxxxxxxxxxxxxx"
                                                     IsEnabled="True"
                                                     FontSize="14"
                                                     Height="40"
                                                     Margin="0,0,12,0"/>
                                            <Button Grid.Column="1"
                                                    Content="Save &amp; Test"
                                                    Command="{Binding TestPatCommand}"
                                                    Background="{StaticResource SystemAccentColorBrush}"
                                                    Foreground="White"
                                                    Padding="20,0"
                                                    Height="40"
                                                    FontWeight="SemiBold"
                                                    CornerRadius="4" />
                                         </Grid>
                                         <TextBlock Text="Try entering 'ghp_demo' and clicking Save &amp; Test to see the validation in action!"
                                                   FontSize="11" Foreground="#666" HorizontalAlignment="Left" Margin="2,0,0,0" />
                                     </StackPanel>
                                </StackPanel>
                            </Border>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: GAME SETTINGS                            -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsGameSettingsSelected}" Margin="0,0,0,50">
          <StackPanel>
             <StackPanel HorizontalAlignment="Left" Spacing="8">
                <TextBlock Text="Interactive Element: Game Options" Classes="demo-title"/>
                <TextBlock Text="Configure game-specific settings without editing files manually." Classes="demo-subtitle"/>

                <!-- Detailed explanations (Game Settings) -->
                <StackPanel Margin="0,12,0,0" Spacing="6">
                    <TextBlock Text="Use this panel to configure resolution, graphics, and compatibility settings. No more editing Options.ini!"
                               FontSize="13" Foreground="#AAAAAA" TextWrapping="Wrap" MaxWidth="900"/>

                    <!-- Settings Explained -->
                    <Border Background="#151515" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#252525" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Key Settings:" FontSize="12" FontWeight="SemiBold" Foreground="#9C27B0" Margin="0,0,0,4"/>
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                <!-- Resolution -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="• Resolution" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Sets the game resolution. Includes support for modern widescreen and 4K resolutions."
                                          Foreground="#888888" FontSize="12" Margin="16,0,0,6" TextWrapping="Wrap"/>

                                <!-- Graphics -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="• Detail Level" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Controls visual quality (Texture, Model, Shadow detail). Higher is better but requires more performance."
                                          Foreground="#888888" FontSize="12" Margin="16,0,0,6" TextWrapping="Wrap"/>

                                <!-- Camera Height -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="• Camera Height" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Adjusts how high the camera can zoom out. 'High' (450-500) is recommended for modern displays."
                                          Foreground="#888888" FontSize="12" Margin="16,0,0,6" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                     <!-- Safe Settings Tip -->
                    <Border Background="#1A0F20" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#3A1C40" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Stability Tips:" FontSize="12" FontWeight="SemiBold" Foreground="#CE93D8" Margin="0,0,0,4"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="• If the game crashes on startup, try disabling 'Use Proxy Library' (GenTool)."
                                          Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="• For multiplayer, ensure 'Quick Match' is disabled."
                                          Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Workflow Guide -->
                    <Border Background="#1A0F20" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#3A1C40" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Step-by-Step Workflow:" FontSize="12" FontWeight="SemiBold" Foreground="#AB47BC" Margin="0,0,0,4"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="1. Adjust Resolution and Detail Level sliders" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="2. Toggle specific fixes like 'Heat Effects' or 'Windowed Mode'" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="3. Changes are auto-saved to Options.ini when you launch the game" Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>

            <Border Classes="demo-container">
               <StackPanel Spacing="20">
                  <TextBlock Text="💡 TIP: You can resize this demo window by dragging the right or bottom edge!"
                             FontSize="12" Foreground="#888888" HorizontalAlignment="Center" FontStyle="Italic"/>

                  <Grid HorizontalAlignment="Center" VerticalAlignment="Top"
                        Width="850" Height="650"
                        ColumnDefinitions="*, Auto" RowDefinitions="*, Auto"
                        MinWidth="500" MinHeight="400">

                      <!-- The Mock Window Content -->
                      <Border Grid.Row="0" Grid.Column="0"
                              Background="#0F0F0F" BorderBrush="#333" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                          <local:DemoGameProfileSettingsWindowMock DataContext="{Binding DemoGameSettings_SettingsTab}"/>
                      </Border>

                      <!-- Horizontal Splitter (Width) -->
                      <GridSplitter Grid.Row="0" Grid.Column="1" Width="4" Background="#1A1A1A" ResizeDirection="Columns" Cursor="SizeWestEast"/>

                      <!-- Vertical Splitter (Height) -->
                      <GridSplitter Grid.Row="1" Grid.Column="0" Height="4" Background="#1A1A1A" ResizeDirection="Rows" Cursor="SizeNorthSouth"/>

                      <!-- Corner Resize Handle (Visual Only) -->
                      <material:MaterialIcon Grid.Row="1" Grid.Column="1" Kind="Resize" Foreground="#444" Width="10" Height="10" Margin="2"/>
                  </Grid>

                  <TextBlock Text="Try adjusting the resolution or enabling experimental features in the Game Settings tab!"
                             FontSize="13" Foreground="#666" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="700" TextWrapping="Wrap"/>
               </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: GAME PROFILE CONTENT                     -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsGameProfileContentSelected}" Margin="0,0,0,50">
          <StackPanel Spacing="20">
             <StackPanel HorizontalAlignment="Left" Spacing="8">
                <TextBlock Text="Interactive Element: Content Editor" Classes="demo-title"/>
                <TextBlock Text="Manage your Mods, Maps, and Patches." Classes="demo-subtitle"/>

                <!-- Detailed explanations -->
                <StackPanel Margin="0,12,0,0" Spacing="6">
                    <TextBlock Text="This demo shows the Content Editor where you combine different types of content into a playable profile. Try clicking the filter buttons and items!"
                               FontSize="13" Foreground="#AAAAAA" TextWrapping="Wrap" MaxWidth="900"/>

                    <!-- Content Types Explained -->
                    <Border Background="#151515" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#252525" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Content Types Explained:" FontSize="12" FontWeight="SemiBold" Foreground="#9C27B0" Margin="0,0,0,4"/>
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                <!-- Game Client -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="• Game Client" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="The actual game executable (generals.exe, game.dat). Required: Every profile MUST have exactly ONE enabled. Examples: Zero Hour v1.04, Generals Online, GenPatcher."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                <!-- Mods -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="• Mods" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Total conversion or major gameplay overhauls. Usually .big files or folders with custom assets. Examples: Rise of the Reds, ShockWave, Contra, The End of Days."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                <!-- Maps -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="• Maps" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Individual custom maps (.map files) for skirmish or multiplayer. Examples: Tournament Desert II, Twilight Flame Optimized."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                <!-- Map Packs -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="• Map Packs" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Collections of maps grouped together. Organize maps by category (competitive, casual, etc.). Examples: 'Ranked 1v1 Maps 2025', 'Co-Op Mission Maps'."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                <!-- Addons -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="• Add-ons" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Cosmetic or audio enhancements that don't change gameplay. Can usually be combined with any mod. Examples: Modern GUI Overlay, HD Sound Effects, Music Packs."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                <!-- Patches -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="• Patches" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="Small modifications, fixes, or enhancements. Applied to base game or specific mods. Examples: GenTool, ControlBar Pro, 4GB Patch, Community Patch 1.06."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                <!-- Modding Tools -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="• Modding Tools" Foreground="#AAAAAA" FontSize="13"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="Utilities for creating or editing game content. Not enabled in game profiles, but can be launched separately. Examples: World Builder, FinalBig, GenPatcher."
                                          Foreground="#888888" FontSize="12" Margin="8,0,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Filter Usage Guide -->
                    <Border Background="#151515" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#252525" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Using Filters:" FontSize="12" FontWeight="SemiBold" Foreground="#9C27B0" Margin="0,0,0,4"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="• Content Type Pills: Click 'Executable', 'Maps', 'Mods', etc. to filter by content type"
                                          Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="• Game Filter Toggle: Switch between 'Generals' and 'Zero Hour' to find compatible content"
                                          Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="• Refresh Icon: Use if you manually added files while the app was open"
                                          Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Combination Examples -->
                    <Border Background="#1A0F20" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#3A1C40" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Real-World Combination Examples:" FontSize="12" FontWeight="SemiBold" Foreground="#CE93D8" Margin="0,0,0,4"/>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Example 1: 'Vanilla Zero Hour' Profile" FontWeight="Medium" Foreground="#AAAAAA" FontSize="12"/>
                                <TextBlock Text="   → Enabled: Zero Hour v1.04 (Game Client)" Foreground="#888888" FontSize="11" Margin="12,0,0,0"/>
                                <TextBlock Text="   → Result: Clean, unmodded game" Foreground="#666666" FontSize="11" Margin="12,0,0,4" FontStyle="Italic"/>

                                <TextBlock Text="Example 2: 'Rise of the Reds' Profile" FontWeight="Medium" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                                <TextBlock Text="   → Enabled: Zero Hour v1.04 (Game Client) + Rise of the Reds 1.87 (Mod) + GenTool v8.9 (Patch)" Foreground="#888888" FontSize="11" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="   → Result: Full RotR experience with GenTool enhancements" Foreground="#666666" FontSize="11" Margin="12,0,0,4" FontStyle="Italic"/>

                                <TextBlock Text="Example 3: 'Competitive 1v1' Profile" FontWeight="Medium" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                                <TextBlock Text="   → Enabled: Generals Online (Game Client) + Ranked 1v1 Maps 2025 (Map Pack) + Community Patch 1.06 (Patch)" Foreground="#888888" FontSize="11" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="   → Result: Optimized setup for online ranked play with only competitive maps" Foreground="#666666" FontSize="11" Margin="12,0,0,4" FontStyle="Italic"/>

                                <TextBlock Text="Example 4: 'Modded + Custom Maps' Profile" FontWeight="Medium" Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0"/>
                                <TextBlock Text="   → Enabled: Zero Hour v1.04 (Game Client) + ShockWave 1.201 (Mod) + Naval Wars Map Pack (Map Pack) + HD Sound Effects (Addon)" Foreground="#888888" FontSize="11" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="   → Result: ShockWave mod with custom maps and improved audio" Foreground="#666666" FontSize="11" Margin="12,0,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Workflow Guide -->
                    <Border Background="#1A0F20" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#3A1C40" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Step-by-Step Workflow:" FontSize="12" FontWeight="SemiBold" Foreground="#AB47BC" Margin="0,0,0,4"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="1. Click the Edit (Pencil) button on a Profile Card" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="2. Go to the Content tab" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="3. On the right (Add Content), find your item and click the '+' button (or the card itself)" Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="4. It moves to the left (Enabled Content)" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="5. To disable: Click the 'X' on an enabled item to move it back to Available" Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="6. Click Save to apply changes" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <Border Classes="demo-container">
               <StackPanel Spacing="20">
                  <TextBlock Text="💡 TIP: You can resize this demo window by dragging the right or bottom edge!"
                             FontSize="12" Foreground="#888888" HorizontalAlignment="Center" FontStyle="Italic"/>

                  <Grid HorizontalAlignment="Center" VerticalAlignment="Top"
                        Width="900" Height="700"
                        ColumnDefinitions="*, Auto" RowDefinitions="*, Auto"
                        MinWidth="600" MinHeight="450">

                      <!-- The Mock Window Content -->
                      <Border Grid.Row="0" Grid.Column="0"
                              Background="#0F0F0F" BorderBrush="#333" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                          <local:DemoGameProfileSettingsWindowMock DataContext="{Binding DemoGameSettings_ContentTab}"/>
                      </Border>

                      <!-- Horizontal Splitter (Width) -->
                      <GridSplitter Grid.Row="0" Grid.Column="1" Width="4" Background="#1A1A1A" ResizeDirection="Columns" Cursor="SizeWestEast"/>

                      <!-- Vertical Splitter (Height) -->
                      <GridSplitter Grid.Row="1" Grid.Column="0" Height="4" Background="#1A1A1A" ResizeDirection="Rows" Cursor="SizeNorthSouth"/>

                      <!-- Corner Resize Handle (Visual Only) -->
                      <material:MaterialIcon Grid.Row="1" Grid.Column="1" Kind="Resize" Foreground="#444" Width="10" Height="10" Margin="2"/>
                  </Grid>

                  <TextBlock Text="Try clicking the filter buttons (Executable, Maps, Mods) and items to see them move between Enabled and Available!"
                             FontSize="13" Foreground="#666" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="700"/>
               </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: TOOLS (Replay & Map)                     -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsToolsSelected}" Margin="0,0,0,50">
            <StackPanel Spacing="60">

                <!-- 1. REPLAY MANAGER -->
                <StackPanel Spacing="40">
                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Left" Spacing="8">
                        <TextBlock Text="Replay Manager" Classes="demo-title"/>
                        <TextBlock Text="Your unified command center for match history." Classes="demo-subtitle"/>
                    </StackPanel>

                    <!-- Interactive Demo -->
                    <Border Classes="demo-container">
                        <Grid Width="800" MaxHeight="600" HorizontalAlignment="Center">
                            <Border Background="#0F0F0F" BorderBrush="#333" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                <toolsRep:ReplayManagerView DataContext="{Binding DemoReplayManager}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Detailed Explanation -->
                    <StackPanel Spacing="20" MaxWidth="900">
                        <!-- Overview -->
                        <TextBlock Text="The Replay Manager is a built-in tool in GenHub that allows you to manage, import, and share your Command &amp; Conquer: Generals and Zero Hour replay files with ease."
                                   Classes="info-overview"/>

                        <!-- Key Features -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleReplayFeaturesExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Key Features" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding ReplayFeaturesExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding ReplayFeaturesExpanded}">

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="ViewDashboard" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Unified View" Classes="info-feature-title"/>
                                        <TextBlock Text="See all your replays for both Generals and Zero Hour in one place."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="Download" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Easy Import" Classes="info-feature-title"/>
                                        <TextBlock Text="Import replays directly from URLs or by dragging and dropping files."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="CloudUpload" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Cloud Sharing" Classes="info-feature-title"/>
                                        <TextBlock Text="Share your best matches instantly via UploadThing."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="FolderZip" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Local Export" Classes="info-feature-title"/>
                                        <TextBlock Text="Bundle multiple replays into a ZIP archive for local storage or manual sharing."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="Pencil" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Rename Replays" Classes="info-feature-title"/>
                                        <TextBlock Text="Double-click any replay file name to rename it directly in the manager."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="CheckboxMultipleMarked" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Multi-Selection" Classes="info-feature-title"/>
                                        <TextBlock Text="Select multiple replays using Ctrl+Click or Shift+Click for batch operations."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        </Border>

                        <!-- Interface Guide -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleReplayInterfaceExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Interface Guide" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding ReplayInterfaceExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding ReplayInterfaceExpanded}">

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Top Toolbar" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="6" Margin="12,0,0,0">
                                        <TextBlock Text="• Game Tabs: Switch between Generals and Zero Hour replays" Classes="info-bullet"/>
                                        <TextBlock Text="• URL Import Bar: Paste a replay URL and click 📥 to import" Classes="info-bullet"/>
                                        <TextBlock Text="• Browse Button: Click 📎 to open a file picker and select replay files" Classes="info-bullet"/>
                                        <TextBlock Text="• Search Bar: Filter your replay list by filename" Classes="info-bullet"/>
                                        <TextBlock Text="• Refresh Button: Click ↻ to reload the replay list" Classes="info-bullet"/>
                                        <TextBlock Text="• Open Folder Button: Click 📁 to open your replay directory in File Explorer" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Replay List" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="6" Margin="12,0,0,0">
                                        <TextBlock Text="• Thumbnail Column: Shows a preview image for each replay (if available)" Classes="info-bullet"/>
                                        <TextBlock Text="• Name Column: Displays the replay filename. Double-click to rename" Classes="info-bullet"/>
                                        <TextBlock Text="• Size Column: Shows the file size in human-readable format (KB, MB)" Classes="info-bullet"/>
                                        <TextBlock Text="• Modified Column: Shows the last modified date of the replay" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Bottom Action Bar" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="6" Margin="12,0,0,0">
                                        <TextBlock Text="• Selected Count: Shows how many replays are currently selected" Classes="info-bullet"/>
                                        <TextBlock Text="• Delete Button: Click 🗑️ to permanently delete selected replays" Classes="info-bullet"/>
                                        <TextBlock Text="• Zip Button: Click 📦 to create a ZIP archive of selected replays" Classes="info-bullet"/>
                                        <TextBlock Text="• Upload Button: Click ☁️ to upload selected replays to the cloud" Classes="info-bullet"/>
                                        <TextBlock Text="• History Button: Click ▼ to view your upload history" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Importing Guide -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleReplayImportingExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Importing Replays" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding ReplayImportingExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding ReplayImportingExpanded}">

                                <StackPanel Spacing="12">
                                    <TextBlock Text="From URL" Classes="info-subsection-title"/>
                                    <TextBlock Text="Paste the link into the import bar and click 📥. Supported sources:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• UploadThing: Direct links from other GenHub users" Classes="info-bullet"/>
                                        <TextBlock Text="• Generals Online: Match view URLs" Classes="info-bullet"/>
                                        <TextBlock Text="• GenTool: Directory URLs from the GenTool data repository" Classes="info-bullet"/>
                                        <TextBlock Text="• Direct Links: Any URL ending in .rep or .zip" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Drag and Drop" Classes="info-subsection-title"/>
                                    <TextBlock Text="Simply drag one or more .rep or .zip files from your computer and drop them anywhere on the Replay Manager window to import them." Classes="info-feature-desc"/>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Browse and Import" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the 📎 button in the toolbar to open a file picker dialog. You can select multiple replay files at once. Supported formats: .rep (individual replay files) and .zip (ZIP archives containing replays)" Classes="info-feature-desc"/>
                                </StackPanel>
                            </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Managing Replays -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleReplayManagingExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Managing Replays" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding ReplayManagingExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding ReplayManagingExpanded}">

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Renaming Replays" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Locate the replay in the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Double-click on the replay name in the Name column" Classes="info-bullet"/>
                                        <TextBlock Text="3. Enter the new name and press Enter" Classes="info-bullet"/>
                                        <TextBlock Text="4. The replay file will be renamed in your replay directory" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Selecting Multiple Replays" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• Ctrl+Click: Click individual replays while holding Ctrl to select/deselect them" Classes="info-bullet"/>
                                        <TextBlock Text="• Shift+Click: Click a replay, then Shift+Click another to select all replays in between" Classes="info-bullet"/>
                                        <TextBlock Text="• Ctrl+A: Press Ctrl+A to select all replays in the current view" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Deleting Replays" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select one or more replays from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Click the 🗑️ Delete button" Classes="info-bullet"/>
                                        <TextBlock Text="3. Confirm the deletion when prompted" Classes="info-bullet"/>
                                        <TextBlock Text="4. Selected replays will be permanently removed from your replay directory" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Opening Replay Folder" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the 📁 Open Folder button in the toolbar to open your game's replay directory in File Explorer:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• Generals: Documents\Command and Conquer Generals Data\Replays" Classes="info-bullet"/>
                                        <TextBlock Text="• Zero Hour: Documents\Command and Conquer Generals Zero Hour Data\Replays" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Exporting & Sharing -->
                        <Border Classes="info-section">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Exporting &amp; Sharing Replays" Classes="info-section-title"/>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Creating ZIP Archives" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select the replays you want to export from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Optionally, enter a custom ZIP name in the text box (default: Replays.zip)" Classes="info-bullet"/>
                                        <TextBlock Text="3. Click the 📦 Zip button" Classes="info-bullet"/>
                                        <TextBlock Text="4. A ZIP archive will be created in your replay directory containing the selected replays" Classes="info-bullet"/>
                                        <TextBlock Text="5. File Explorer will open highlighting the created ZIP file" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Uploading to Cloud" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select the replays you want to share from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Click the ☁️ Upload button" Classes="info-bullet"/>
                                        <TextBlock Text="3. Wait for the upload to complete (progress bar will show)" Classes="info-bullet"/>
                                        <TextBlock Text="4. Once complete, the download link will be copied to your clipboard automatically" Classes="info-bullet"/>
                                        <TextBlock Text="5. Share the link with others via Discord, email, or any messaging app" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="#2A1A3A" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="⚠️ IMPORTANT" FontWeight="SemiBold" Foreground="#FF6B6B" FontSize="12"/>
                                        <TextBlock Text="• Size Limit: Each individual replay or ZIP file must be under 1 MB" Foreground="#FFAAAA" FontSize="11"/>
                                        <TextBlock Text="• Privacy: Shared replays are maintained for up to 14 days or until storage is full" Foreground="#FFAAAA" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Upload History" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the ▼ History button to view your upload history:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• File Name: Shows the name of the uploaded file" Classes="info-bullet"/>
                                        <TextBlock Text="• Timestamp: Shows when the upload was made" Classes="info-bullet"/>
                                        <TextBlock Text="• Size: Shows the file size" Classes="info-bullet"/>
                                        <TextBlock Text="• Status: Shows if the link is still active (green) or expired (red)" Classes="info-bullet"/>
                                        <TextBlock Text="• Copy Link: Click the 📋 button to copy the download link" Classes="info-bullet"/>
                                        <TextBlock Text="• Remove: Click the 🗑️ button to remove an item from history (frees up your upload quota)" Classes="info-bullet"/>
                                        <TextBlock Text="• Clear All: Click the button at the bottom to clear your entire upload history" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="#1A2A2A" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="ℹ️ NOTE" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="12"/>
                                        <TextBlock Text="Removing items from your upload history frees up your upload quota immediately, allowing you to upload more files." Foreground="#A0FFA0" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- 2. MAP MANAGER -->
                <StackPanel Spacing="40">
                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Left" Spacing="8">
                        <TextBlock Text="Map Manager" Classes="demo-title"/>
                        <TextBlock Text="Curate, validate, and share your battlegrounds." Classes="demo-subtitle"/>
                    </StackPanel>

                    <!-- Interactive Demo -->
                    <Border Classes="demo-container">
                        <Grid Width="800" MaxHeight="600" HorizontalAlignment="Center">
                            <Border Background="#0F0F0F" BorderBrush="#333" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                <toolsMap:MapManagerView DataContext="{Binding DemoMapManager}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Detailed Explanation -->
                    <StackPanel Spacing="20" MaxWidth="900">
                        <!-- Overview -->
                        <TextBlock Text="The Map Manager is a built-in tool in GenHub that allows you to manage, import, and share your Command &amp; Conquer: Generals and Zero Hour custom maps with ease. It also features MapPacks for organizing maps into collections."
                                   Classes="info-overview"/>

                        <!-- Key Features -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleMapFeaturesExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Key Features" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding MapFeaturesExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding MapFeaturesExpanded}">

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="ViewDashboard" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Unified View" Classes="info-feature-title"/>
                                        <TextBlock Text="See all your maps for both Generals and Zero Hour in one place."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="Download" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Easy Import" Classes="info-feature-title"/>
                                        <TextBlock Text="Import maps directly from URLs or by dragging and dropping files."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="CloudUpload" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Cloud Sharing" Classes="info-feature-title"/>
                                        <TextBlock Text="Share your custom maps instantly via UploadThing."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="FolderZip" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Local Export" Classes="info-feature-title"/>
                                        <TextBlock Text="Bundle multiple maps into a ZIP archive for local storage or manual sharing."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="Package" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="MapPacks" Classes="info-feature-title"/>
                                        <TextBlock Text="Create named collections of maps for easy organization and profile management."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="AlertCircle" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Validation" Classes="info-feature-title"/>
                                        <TextBlock Text="Automatically detects missing preview images (TGA) that cause game crashes."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="Pencil" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Rename Maps" Classes="info-feature-title"/>
                                        <TextBlock Text="Double-click any map name to rename it directly in the manager."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <material:MaterialIcon Grid.Column="0" Kind="CheckboxMultipleMarked" Classes="info-feature-icon"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="4">
                                        <TextBlock Text="Multi-Selection" Classes="info-feature-title"/>
                                        <TextBlock Text="Select multiple maps using Ctrl+Click or Shift+Click for batch operations."
                                                  Classes="info-feature-desc"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        </Border>

                        <!-- Interface Guide -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleMapInterfaceExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Interface Guide" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding MapInterfaceExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding MapInterfaceExpanded}">

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Top Toolbar" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="6" Margin="12,0,0,0">
                                        <TextBlock Text="• Game Tabs: Switch between Generals and Zero Hour maps" Classes="info-bullet"/>
                                        <TextBlock Text="• URL Import Bar: Paste a map URL and click 📥 to import" Classes="info-bullet"/>
                                        <TextBlock Text="• Browse Button: Click 📎 to open a file picker and select map files" Classes="info-bullet"/>
                                        <TextBlock Text="• Search Bar: Filter your map list by filename" Classes="info-bullet"/>
                                        <TextBlock Text="• Refresh Button: Click ↻ to reload the map list" Classes="info-bullet"/>
                                        <TextBlock Text="• Open Folder Button: Click 📁 to open your map directory in File Explorer" Classes="info-bullet"/>
                                        <TextBlock Text="• MapPacks Button: Click the Pack button to open the MapPack Manager" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Map List" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="6" Margin="12,0,0,0">
                                        <TextBlock Text="• Thumbnail Column: Shows a preview image for each map (if available)" Classes="info-bullet"/>
                                        <TextBlock Text="• Name Column: Displays the map filename. Double-click to rename" Classes="info-bullet"/>
                                        <TextBlock Text="• Size Column: Shows the file size in human-readable format (KB, MB)" Classes="info-bullet"/>
                                        <TextBlock Text="• Type Column: Shows the map type (Map: standard map with assets, Archive: ZIP archive)" Classes="info-bullet"/>
                                        <TextBlock Text="• Modified Column: Shows the last modified date of the map" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Bottom Action Bar" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="6" Margin="12,0,0,0">
                                        <TextBlock Text="• Selected Count: Shows how many maps are currently selected" Classes="info-bullet"/>
                                        <TextBlock Text="• Delete Button: Click 🗑️ to permanently delete selected maps" Classes="info-bullet"/>
                                        <TextBlock Text="• Uncompress Button: Click 📦🔓 to extract maps from selected ZIP archives" Classes="info-bullet"/>
                                        <TextBlock Text="• ZIP Name: Enter a custom filename for the ZIP archive (default: Maps.zip)" Classes="info-bullet"/>
                                        <TextBlock Text="• Zip Button: Click 📦 to create a ZIP archive of selected maps" Classes="info-bullet"/>
                                        <TextBlock Text="• Upload Button: Click ☁️ to upload selected maps to the cloud" Classes="info-bullet"/>
                                        <TextBlock Text="• History Button: Click ▼ to view your upload history" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Importing Guide -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleMapImportingExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Importing Maps" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding MapImportingExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding MapImportingExpanded}">

                                <StackPanel Spacing="12">
                                    <TextBlock Text="From URL" Classes="info-subsection-title"/>
                                    <TextBlock Text="Paste the link into the import bar and click 📥. Supported sources:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• UploadThing: Direct links from other GenHub users" Classes="info-bullet"/>
                                        <TextBlock Text="• Direct Links: Any URL ending in .map or .zip" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Drag and Drop" Classes="info-subsection-title"/>
                                    <TextBlock Text="Simply drag one or more .map or .zip files from your computer and drop them anywhere on the Map Manager window to import them." Classes="info-feature-desc"/>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Browse and Import" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the 📎 button in the toolbar to open a file picker dialog. You can select multiple map files at once. Supported formats: .map (individual map files) and .zip (ZIP archives containing maps)" Classes="info-feature-desc"/>
                                </StackPanel>
                            </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Managing Maps -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleMapManagingExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Managing Maps" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding MapManagingExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding MapManagingExpanded}">

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Renaming Maps" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Locate the map in the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Double-click on the map name in the Name column" Classes="info-bullet"/>
                                        <TextBlock Text="3. Enter the new name and press Enter" Classes="info-bullet"/>
                                        <TextBlock Text="4. The map file or directory will be renamed in your map directory" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Selecting Multiple Maps" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• Ctrl+Click: Click individual maps while holding Ctrl to select/deselect them" Classes="info-bullet"/>
                                        <TextBlock Text="• Shift+Click: Click a map, then Shift+Click another to select all maps in between" Classes="info-bullet"/>
                                        <TextBlock Text="• Ctrl+A: Press Ctrl+A to select all maps in the current view" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Deleting Maps" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select one or more maps from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Click the 🗑️ Delete button" Classes="info-bullet"/>
                                        <TextBlock Text="3. Confirm the deletion when prompted" Classes="info-bullet"/>
                                        <TextBlock Text="4. Selected maps will be permanently removed from your map directory" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Opening Map Folder" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the 📁 Open Folder button in the toolbar to open your game's map directory in File Explorer:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• Generals: Documents\Command and Conquer Generals Data\Maps" Classes="info-bullet"/>
                                        <TextBlock Text="• Zero Hour: Documents\Command and Conquer Generals Zero Hour Data\Maps" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Exporting & Sharing -->
                        <Border Classes="info-section">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Exporting &amp; Sharing Maps" Classes="info-section-title"/>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Creating ZIP Archives" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select the maps you want to export from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Optionally, enter a custom ZIP name in the text box (default: Maps.zip)" Classes="info-bullet"/>
                                        <TextBlock Text="3. Click the 📦 Zip button" Classes="info-bullet"/>
                                        <TextBlock Text="4. A ZIP archive will be created in your map directory containing the selected maps" Classes="info-bullet"/>
                                        <TextBlock Text="5. File Explorer will open highlighting the created ZIP file" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Uncompressing ZIP Archives" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select the ZIP file(s) from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Click the 📦🔓 Uncompress button (appears when ZIP files are selected)" Classes="info-bullet"/>
                                        <TextBlock Text="3. The maps inside the ZIP will be extracted to your map directory" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Uploading to Cloud" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select the maps you want to share from the list" Classes="info-bullet"/>
                                        <TextBlock Text="2. Click the ☁️ Upload button" Classes="info-bullet"/>
                                        <TextBlock Text="3. Wait for the upload to complete (progress bar will show)" Classes="info-bullet"/>
                                        <TextBlock Text="4. Once complete, the download link will be copied to your clipboard automatically" Classes="info-bullet"/>
                                        <TextBlock Text="5. Share the link with others via Discord, email, or any messaging app" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="#2A1A3A" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="⚠️ IMPORTANT" FontWeight="SemiBold" Foreground="#FF6B6B" FontSize="12"/>
                                        <TextBlock Text="• Size Limit: Each individual map file must be under 5 MB" Foreground="#FFAAAA" FontSize="11"/>
                                        <TextBlock Text="• Privacy: Shared maps are maintained for up to 14 days or until storage is full" Foreground="#FFAAAA" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Upload History" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the ▼ History button to view your upload history:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• File Name: Shows the name of the uploaded file" Classes="info-bullet"/>
                                        <TextBlock Text="• Timestamp: Shows when the upload was made" Classes="info-bullet"/>
                                        <TextBlock Text="• Size: Shows the file size" Classes="info-bullet"/>
                                        <TextBlock Text="• Status: Shows if the link is still active (green) or expired (red)" Classes="info-bullet"/>
                                        <TextBlock Text="• Copy Link: Click the 📋 button to copy the download link" Classes="info-bullet"/>
                                        <TextBlock Text="• Remove: Click the 🗑️ button to remove an item from history (frees up your upload quota)" Classes="info-bullet"/>
                                        <TextBlock Text="• Clear All: Click the button at the bottom to clear your entire upload history" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="#1A2A2A" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="ℹ️ NOTE" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="12"/>
                                        <TextBlock Text="Removing items from your upload history frees up your upload quota immediately, allowing you to upload more files." Foreground="#A0FFA0" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- MapPacks Section -->
                        <Border Classes="info-section">
                            <StackPanel>
                                <!-- Header with Toggle -->
                                <Button Command="{Binding ToggleMapPacksExpanded}" Classes="info-section-header">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="MapPacks" Classes="info-section-title" VerticalAlignment="Center"/>
                                        <material:MaterialIcon Grid.Column="2" Kind="{Binding MapPacksExpanded, Converter={StaticResource BoolToExpandIconConverter}}" Classes="info-section-icon" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <!-- Content -->
                                <StackPanel Classes="info-section-content" IsVisible="{Binding MapPacksExpanded}">

                                <TextBlock Text="MapPacks allow you to organize maps into named collections. This is especially useful for managing different map sets for different profiles or game modes." Classes="info-feature-desc"/>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Creating a MapPack" Classes="info-subsection-title"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="1. Select the maps you want to include in the pack" Classes="info-bullet"/>
                                        <TextBlock Text="2. Click the 📦 MapPacks button in the toolbar" Classes="info-bullet"/>
                                        <TextBlock Text="3. Enter a name and optional description" Classes="info-bullet"/>
                                        <TextBlock Text="4. Click Create MapPack" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Managing MapPacks" Classes="info-subsection-title"/>
                                    <TextBlock Text="Click the 📦 MapPacks button to open the MapPack Manager panel:" Classes="info-feature-desc" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4" Margin="12,0,0,0">
                                        <TextBlock Text="• Existing MapPacks: Shows all your created MapPacks with name, created date, maps count, and loaded status" Classes="info-bullet"/>
                                        <TextBlock Text="• Load MapPack: Click the Load button to enable a MapPack for a profile" Classes="info-bullet"/>
                                        <TextBlock Text="• Unload MapPack: Click the Unload button to disable a MapPack" Classes="info-bullet"/>
                                        <TextBlock Text="• Delete MapPack: Click the 🗑️ button to permanently delete a MapPack" Classes="info-bullet"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Using MapPacks" Classes="info-subsection-title"/>
                                    <TextBlock Text="MapPacks are stored as metadata and integrate with GenHub's userdata system. When you load a MapPack for a profile, the maps will be automatically activated by the userdata system when that profile is launched." Classes="info-feature-desc"/>
                                </StackPanel>

                                <Border Background="#1A2A2A" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="ℹ️ NOTE" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="12"/>
                                        <TextBlock Text="Integration with Profiles: MapPacks work seamlessly with GenHub's profile system. Maps from loaded MapPacks are managed by the userdata service, which handles file linking and cleanup automatically." Foreground="#A0FFA0" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                                </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: SCAN FOR GAMES                           -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsScanForGamesSelected}" Margin="0,0,0,50">
          <StackPanel>
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Interactive Element: Scan Wizard" Classes="demo-title"/>
                <TextBlock Text="How GenHub finds games on your PC." Classes="demo-subtitle"/>
            </StackPanel>

            <Border Classes="demo-container">
               <views:ScanWizardDemoView Height="450" HorizontalAlignment="Center" />
            </Border>
          </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: LOCAL CONTENT                            -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsLocalContentSelected}" Margin="0,0,0,50">
             <StackPanel Spacing="20">
                <StackPanel HorizontalAlignment="Left" Spacing="8">
                    <TextBlock Text="Interactive Element: Import Wizard" Classes="demo-title"/>
                    <TextBlock Text="Add your own content to game profiles." Classes="demo-subtitle"/>

                    <!-- Detailed explanations -->
                    <StackPanel Margin="0,12,0,0" Spacing="6">
                        <TextBlock Text="This demo shows how to import local content into GenHub. Click the buttons to see what each one does!"
                                   FontSize="13" Foreground="#AAAAAA" TextWrapping="Wrap" MaxWidth="900"/>

                        <!-- Content Types Explained -->
                        <Border Background="#151515" CornerRadius="8" Padding="16" Margin="0,8,0,0" BorderBrush="#252525" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Content Types You Can Import:" FontSize="12" FontWeight="SemiBold" Foreground="#5E35B1" Margin="0,0,0,4"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                    <!-- Mods -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="• Mods" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Game modifications that change gameplay, units, or graphics. Example: Rise of the Reds, ShockWave."
                                              Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                    <!-- Addons -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="• Addons" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Smaller additions that enhance the base game. Example: UI overlays, HD sound packs."
                                              Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                    <!-- Tools -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="• Tools" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Standalone utilities for modding. Example: World Builder, FinalBig, Particle Editor, Wind Editor."
                                              Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                    <!-- Maps -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="• Maps" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Individual map files (.map) for multiplayer or skirmish play."
                                              Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                    <!-- Map Packs -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="• Map Packs" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Collections of maps bundled together. Example: Tournament Map Pack, Co-Op Mission Maps."
                                              Foreground="#888888" FontSize="12" Margin="8,0,0,6" TextWrapping="Wrap"/>

                                    <!-- Missions -->
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="• Missions" Foreground="#AAAAAA" FontSize="13"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="Single-player scenarios and custom campaigns."
                                              Foreground="#888888" FontSize="12" Margin="8,0,0,0" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Availability Note -->
                        <Border Background="#1A3A2A" CornerRadius="8" Padding="12" Margin="0,8,0,0" BorderBrush="#2A5A3A" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="This feature is available by clicking the 'Add Local Content' button in the Game Profile Settings window."
                                          FontSize="12" Foreground="#4CAF50" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Expanded demo container with proper width -->
                <Border Classes="demo-container" Padding="40,30">
                   <!-- Use Viewbox to scale content while maintaining aspect ratio -->
                   <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Center">
                       <!-- SIMULATED WINDOW FRAME -->
                       <Panel Width="800" Height="600">
                            <!-- Acrylic Tint Layer Simulation -->
                            <ExperimentalAcrylicBorder IsHitTestVisible="False">
                                <ExperimentalAcrylicBorder.Material>
                                    <ExperimentalAcrylicMaterial
                                        BackgroundSource="Digger"
                                        TintColor="Black"
                                        TintOpacity="0.85"
                                        MaterialOpacity="0.65" />
                                </ExperimentalAcrylicBorder.Material>
                            </ExperimentalAcrylicBorder>

                            <!-- Main Content Border and Title Bar -->
                            <Border BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="0" Background="#CC000000">
                                <Grid RowDefinitions="30,*" Margin="20,10,20,20">
                                    <!-- Custom Title Bar Drag Area Simulation -->
                                    <Grid Grid.Row="0" Background="Transparent" IsHitTestVisible="False">
                                        <TextBlock Text="Add Local Content"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#80FFFFFF"
                                                   FontSize="12"
                                                   IsHitTestVisible="False"/>
                                    </Grid>

                                    <!-- Extracted Content View -->
                                    <local:AddLocalContentView Grid.Row="1" DataContext="{Binding DemoAddLocalContent}"/>
                                </Grid>
                            </Border>
                       </Panel>
                   </Viewbox>
                </Border>

                <!-- Button Explanations -->
                <Border Background="#151515" CornerRadius="8" Padding="16" BorderBrush="#252525" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Button Explanations:" FontSize="12" FontWeight="SemiBold" Foreground="#5E35B1"/>
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="📁 Browse Folder" Foreground="#AAAAAA" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Grid.Column="1" Text="Opens a folder picker to select a mod or map directory containing game files."
                                          Foreground="#888888" FontSize="12" Margin="12,0,0,0" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="📦 Browse Files" Foreground="#AAAAAA" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Grid.Column="1" Text="Opens a file picker to select .zip archives or individual files to import."
                                          Foreground="#888888" FontSize="12" Margin="12,0,0,0" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="✕ Remove" Foreground="#AAAAAA" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Grid.Column="1" Text="Removes a file or folder from the content preview before importing."
                                          Foreground="#888888" FontSize="12" Margin="12,0,0,0" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="✓ ADD CONTENT" Foreground="#AAAAAA" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Grid.Column="1" Text="Imports the selected content into GenHub's library for use with game profiles."
                                          Foreground="#888888" FontSize="12" Margin="12,0,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
             </StackPanel>
        </Border>

        <!-- ============================================== -->
        <!-- DEMO: CHANGELOGS                               -->
        <!-- ============================================== -->
        <Border IsVisible="{Binding IsChangelogsSelected}" Margin="0,0,0,50">
            <views:ChangelogsView DataContext="{Binding Changelogs}"/>
        </Border>

        <!-- ============================================== -->
        <!-- INFO CARDS (Dynamic Content)                   -->
        <!-- ============================================== -->
        <ItemsControl ItemsSource="{Binding SelectedSection.Cards}" Padding="0,0,0,20">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:InfoCardViewModel">
              <Border Classes="info-card">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto">

                  <!-- Card Header -->
                  <Grid ColumnDefinitions="Auto, *, Auto" Grid.Row="0" Margin="0,0,0,16">
                     <!-- Icon -->
                    <material:MaterialIcon Kind="{Binding IconKey}"
                                            Width="32" Height="32"
                                            Foreground="{StaticResource SystemAccentColorBrush}"
                                            IsVisible="{Binding IconKey, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Margin="0,0,18,0"/>

                    <!-- Title -->
                    <TextBlock Text="{Binding Title}" Grid.Column="1" Classes="card-title" VerticalAlignment="Center" TextWrapping="Wrap"/>

                    <!-- Expand Button (Subtle) -->
                    <Button Grid.Column="2"
                            IsVisible="{Binding IsExpandable}"
                            Command="{Binding ToggleExpansionCommand}"
                            Background="#181818"
                            BorderBrush="#444"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToExpandTextConverter}, FallbackValue='Read More'}"
                                     FontSize="12" Foreground="#999" VerticalAlignment="Center"/>
                          <material:MaterialIcon Kind="{Binding IsExpanded, Converter={StaticResource BoolToExpandIconConverter}}"
                                                 Width="16" Height="16" Foreground="#999"/>
                      </StackPanel>
                    </Button>
                  </Grid>

                  <!-- Main Content (Always visible) -->
                  <infra:MarkdownTextBlock Grid.Row="1" Markdown="{Binding Content}" Classes="card-content" Margin="0,0,0,24" FontSize="15" Foreground="#CCC"/>

                  <!-- Expanded Content ('God Tier' Details) -->
                  <Border Grid.Row="2"
                          IsVisible="{Binding IsExpanded}"
                          Background="#161616"
                          BorderBrush="#252525"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="24"
                          Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="DETAILED GUIDE"  FontSize="11" FontWeight="Bold" Foreground="#666" Margin="0,0,0,12"/>
                        <infra:MarkdownTextBlock Markdown="{Binding DetailedContent}" Classes="card-content" FontSize="14" Foreground="#BBB"/>
                    </StackPanel>
                  </Border>

                  <!-- Actions Footer -->
                  <ItemsControl Grid.Row="3" ItemsSource="{Binding Actions}" IsVisible="{Binding Actions.Count}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:InfoAction">
                        <Button Classes="action-btn"
                                Classes.primary="{Binding IsPrimary}"
                                Command="{Binding ((vm:GenHubInfoSectionViewModel)DataContext).HandleActionCommand, RelativeSource={RelativeSource AncestorType=views:GenHubInfoSectionView}}"
                                CommandParameter="{Binding}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="{Binding IconKey}" Width="16" Height="16" IsVisible="{Binding IconKey, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="{Binding Label}"/>
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Height="120"/> <!-- Bottom padding increased to fix clipping -->
      </StackPanel>
  </ScrollViewer>
</UserControl>
